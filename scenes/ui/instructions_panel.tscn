[node name="ObjectiveSection" type="VBoxContainer" parent="Panel/Center/Card/VBox"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="ObjectiveHead" type="Label" parent="Panel/Center/Card/VBox/ObjectiveSection"]
layout_mode = 2
theme_override_colors/font_color = Color(0.95, 0.42, 0.88, 1)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 14
text = "OBJECTIVE"

[node name="Objective" type="Label" parent="Panel/Center/Card/VBox/ObjectiveSection"]
layout_mode = 2
theme_override_colors/font_color = Color(0.95, 0.95, 0.97, 1)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 15
text = "Wake every machine in the room by kicking the ball into it. Clear them all to open the way to the next room."
autowrap_mode = 2

[node name="KickSection" type="VBoxContainer" parent="Panel/Center/Card/VBox"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="KickHead" type="Label" parent="Panel/Center/Card/VBox/KickSection"]
layout_mode = 2
theme_override_colors/font_color = Color(0.95, 0.42, 0.88, 1)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 14
text = "KICK & AIM"

[node name="Kick" type="Label" parent="Panel/Center/Card/VBox/KickSection"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.92, 0.96, 1)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 15
theme_override_constants/line_spacing = 2
autowrap_mode = 2
text = "SPACE — hold to charge, release to fire
MOUSE — aim (the ball kicks toward your cursor)
Hold past full charge — risk an OVERCHARGE shot: more power, less accuracy
One FINAL KICK burst is available per level for an emergency full-power shot"

[node name="RewindSection" type="VBoxContainer" parent="Panel/Center/Card/VBox"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="RewindHead" type="Label" parent="Panel/Center/Card/VBox/RewindSection"]
layout_mode = 2
theme_override_colors/font_color = Color(0.95, 0.42, 0.88, 1)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 14
text = "REWIND & SCRUB"

[node name="Rewind" type="Label" parent="Panel/Center/Card/VBox/RewindSection"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.92, 0.96, 1)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 15
theme_override_constants/line_spacing = 2
autowrap_mode = 2
text = "R + LEFT / RIGHT — rewind or fast-forward the ball's last ~10 seconds
Release R to resume play from that point — undo a bad kick or a fall"

[node name="CameraSection" type="VBoxContainer" parent="Panel/Center/Card/VBox"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="CameraHead" type="Label" parent="Panel/Center/Card/VBox/CameraSection"]
