theme_override_font_sizes/font_size = 14
text = "CAMERA"

[node name="Camera" type="Label" parent="Panel/Center/Card/VBox/CameraSection"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.92, 0.96, 1)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 15
theme_override_constants/line_spacing = 2
autowrap_mode = 2
text = "RIGHT-DRAG — orbit freely around the room to line up any gear
SCROLL WHEEL or + / - — zoom in and out
HOME — reset the camera to the level's default view
P — pause the game"

