[node name="ObjectiveHead" type="Label" parent="Panel/Center/Card/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.714, 0.153, 0.9)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 13
text = "OBJECTIVE"

[node name="Objective" type="Label" parent="Panel/Center/Card/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.918, 0.918, 0.918, 1)
theme_override_font_sizes/font_size = 16
text = "Wake every machine in the room by kicking the ball into it. Clear them all to open the way to the next room."
autowrap_mode = 2

[node name="KickHead" type="Label" parent="Panel/Center/Card/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.714, 0.153, 0.9)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 13
text = "KICK & AIM"

[node name="Kick" type="Label" parent="Panel/Center/Card/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.82, 0.84, 0.87, 1)
theme_override_font_sizes/font_size = 15
text = "SPACE — hold to charge, release to fire
MOUSE — aim (the ball kicks toward your cursor)
Hold past full charge — risk an OVERCHARGE shot: more power, less accuracy
One FINAL KICK burst is available per level for an emergency full-power shot"

[node name="RewindHead" type="Label" parent="Panel/Center/Card/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.714, 0.153, 0.9)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 13
text = "REWIND & SCRUB"

[node name="Rewind" type="Label" parent="Panel/Center/Card/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.82, 0.84, 0.87, 1)
theme_override_font_sizes/font_size = 15
text = "R + LEFT / RIGHT — rewind or fast-forward the ball's last ~10 seconds
Release R to resume play from that point — undo a bad kick or a fall"

[node name="CameraHead" type="Label" parent="Panel/Center/Card/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.714, 0.153, 0.9)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 13
text = "CAMERA"

[node name="Camera" type="Label" parent="Panel/Center/Card/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.82, 0.84, 0.87, 1)
theme_override_font_sizes/font_size = 15
text = "RIGHT-DRAG — orbit freely around the room to line up any gear
SCROLL WHEEL or + / − — zoom in and out
HOME — reset the camera to the level's default view
ESC — pause the game"

[node name="BackButton" type="Button" parent="Panel/Center/Card/VBox"]
