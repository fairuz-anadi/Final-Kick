[node name="TitleScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("2")
script = ExtResource("1")

[node name="BG" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.059, 0.067, 0.082, 1)

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Center"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Eyebrow" type="Label" parent="Center/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.961, 0.651, 0.137, 1)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 13
text = "IUT 12TH ICT FEST GAMEJAM  ·  THEME: KICKOFF"
horizontal_alignment = 1

[node name="Title" type="Label" parent="Center/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.918, 0.918, 0.918, 1)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 84
text = "FINAL KICK"
horizontal_alignment = 1

[node name="Tagline" type="Label" parent="Center/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.659, 0.678, 0.71, 1)
theme_override_font_sizes/font_size = 17
text = "One kick. One chance. Rewind, aim again, and wake the machine up for good."
horizontal_alignment = 1

[node name="Spacer" type="Control" parent="Center/VBox"]
custom_minimum_size = Vector2(0, 18)
layout_mode = 2

[node name="StartButton" type="Button" parent="Center/VBox"]
layout_mode = 2
size_flags_horizontal = 4
theme_override_font_sizes/font_size = 17
theme_override_styles/normal = SubResource("StyleBoxFlat_btn")
theme_override_styles/hover = SubResource("StyleBoxFlat_btn_hover")
theme_override_styles/pressed = SubResource("StyleBoxFlat_btn_pressed")
theme_override_colors/font_color = Color(0.918, 0.918, 0.918, 1)
theme_override_colors/font_hover_color = Color(0.04, 0.05, 0.09, 1)
text = "START  —  press SPACE"

[node name="Controls" type="Label" parent="Center/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.659, 0.678, 0.71, 0.9)
theme_override_font_sizes/font_size = 13
text = "SPACE hold / release — kick  ·  MOUSE — aim  ·  R + LEFT / RIGHT — rewind"
horizontal_alignment = 1

[node name="QuitButton" type="Button" parent="Center/VBox"]
layout_mode = 2
size_flags_horizontal = 4
theme_override_font_sizes/font_size = 14
theme_override_styles/normal = SubResource("StyleBoxFlat_btn")
theme_override_styles/hover = SubResource("StyleBoxFlat_btn_hover")
theme_override_styles/pressed = SubResource("StyleBoxFlat_btn_pressed")
theme_override_colors/font_color = Color(0.659, 0.678, 0.71, 1)
theme_override_colors/font_hover_color = Color(0.04, 0.05, 0.09, 1)
text = "QUIT"

[node name="Footer" type="Label" parent="."]
layout_mode = 1
anchors_preset = 12
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = -40.0
offset_bottom = -16.0
