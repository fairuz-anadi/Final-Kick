corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_right = 8
corner_radius_bottom_left = 8

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_btn_hover"]
content_margin_left = 26.0
content_margin_top = 12.0
content_margin_right = 26.0
content_margin_bottom = 12.0
bg_color = Color(0.961, 0.651, 0.137, 1)
corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_right = 8
corner_radius_bottom_left = 8

[node name="Ending" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("2")
script = ExtResource("1")

[node name="BG" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.059, 0.067, 0.082, 1)

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Center"]
layout_mode = 2
theme_override_constants/separation = 20

[node name="Title" type="Label" parent="Center/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.24, 0.5, 1)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 40
text = "THE FACTORY BREATHES AGAIN"
horizontal_alignment = 1

[node name="Body" type="Label" parent="Center/VBox"]
custom_minimum_size = Vector2(580, 0)
layout_mode = 2
theme_override_colors/font_color = Color(0.82, 0.84, 0.87, 1)
theme_override_font_sizes/font_size = 17
text = "You thought you were the only thing still moving in here. You weren't. At the center of it all was the very first machine this factory ever built — the one every other machine had spent years silently guarding, waiting for someone who was never supposed to come back. Then you kicked. Not just a gear. Not just a wire, a vial. The whole factory lurched awake at once — lights down hallways you never knew existed, something enormous exhaling somewhere beneath your feet. You didn't just fix one machine today. You woke up everything this place ever was."
horizontal_alignment = 1
autowrap_mode = 2

[node name="Credits" type="Label" parent="Center/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.659, 0.678, 0.71, 1)
theme_override_font_sizes/font_size = 14
text = "SYSTEMS & PHYSICS
LEVEL DESIGN & SOUND
ART, UI & SHADERS"
horizontal_alignment = 1

[node name="BackButton" type="Button" parent="Center/VBox"]
layout_mode = 2
size_flags_horizontal = 4
theme_override_font_sizes/font_size = 15
theme_override_styles/normal = SubResource("StyleBoxFlat_btn")
theme_override_styles/hover = SubResource("StyleBoxFlat_btn_hover")
theme_override_colors/font_color = Color(0.918, 0.918, 0.918, 1)
theme_override_colors/font_hover_color = Color(0.04, 0.05, 0.09, 1)
text = "BACK TO TITLE"

[connection signal="pressed" from="Center/VBox/BackButton" to="." method="_on_back_pressed"]
