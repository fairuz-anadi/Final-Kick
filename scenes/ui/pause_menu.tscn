[gd_scene load_steps=7 format=3]

[ext_resource type="Script" path="res://scripts/ui/pause_menu.gd" id="1"]
[ext_resource type="Theme" path="res://assets/ui/theme.tres" id="2"]
[ext_resource type="FontFile" path="res://assets/fonts/PixelGame.otf" id="3"]
[ext_resource type="Shader" path="res://assets/shaders/blur_dim.gdshader" id="4"]
[ext_resource type="Shader" path="res://assets/shaders/gradient_vision.gdshader" id="5"]
[ext_resource type="Script" path="res://scripts/ui/neon_cut_button.gd" id="6"]

[sub_resource type="ShaderMaterial" id="ShaderMaterial_blur"]
shader = ExtResource("4")

[sub_resource type="ShaderMaterial" id="ShaderMaterial_vision"]
shader = ExtResource("5")
shader_parameter/vignette_amount = 0.7
shader_parameter/opacity = 0.75

[sub_resource type="StyleBoxEmpty" id="StyleBoxEmpty_btn"]
content_margin_left = 24.0
content_margin_top = 11.0
content_margin_right = 24.0
content_margin_bottom = 11.0

[node name="PauseMenu" type="CanvasLayer"]
process_mode = 3
layer = 10
script = ExtResource("1")

[node name="Panel" type="Control" parent="."]
unique_name_in_owner = true
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("2")

[node name="Dim" type="ColorRect" parent="Panel"]
layout_mode = 1
material = SubResource("ShaderMaterial_blur")
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.7)

[node name="GradientVision" type="ColorRect" parent="Panel"]
layout_mode = 1
material = SubResource("ShaderMaterial_vision")
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

[node name="Center" type="CenterContainer" parent="Panel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Panel/Center"]
layout_mode = 2
theme_override_constants/separation = 18

[node name="GameName" type="Label" parent="Panel/Center/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.95, 0.42, 0.88, 0.9)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 20
text = "FINAL KICK"
horizontal_alignment = 1

[node name="Title" type="Label" parent="Panel/Center/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.15, 0.95, 1, 1)
theme_override_colors/font_outline_color = Color(0, 0, 0, 1)
theme_override_constants/outline_size = 7
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 78
text = "GAME PAUSED"
horizontal_alignment = 1

[node name="Buttons" type="HBoxContainer" parent="Panel/Center/VBox"]
layout_mode = 2
theme_override_constants/separation = 14
alignment = 1

[node name="RestartButton" type="Button" parent="Panel/Center/VBox/Buttons"]
layout_mode = 2
script = ExtResource("6")
accent_color = Color(0.6, 0.68, 0.78, 1)
fill_color = Color(0.1, 0.12, 0.16, 1)
glow_strength = 0.4
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 21
theme_override_styles/normal = SubResource("StyleBoxEmpty_btn")
theme_override_styles/hover = SubResource("StyleBoxEmpty_btn")
theme_override_styles/pressed = SubResource("StyleBoxEmpty_btn")
theme_override_styles/focus = SubResource("StyleBoxEmpty_btn")
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_hover_color = Color(1, 1, 1, 1)
theme_override_colors/font_pressed_color = Color(1, 1, 1, 1)
theme_override_colors/font_focus_color = Color(1, 1, 1, 1)
theme_override_colors/font_outline_color = Color(0, 0, 0, 0.9)
theme_override_constants/outline_size = 3
text = "RESTART"

