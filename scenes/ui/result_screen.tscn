[gd_scene load_steps=10 format=3]

[ext_resource type="Script" path="res://scripts/ui/result_screen.gd" id="1"]
[ext_resource type="Theme" path="res://assets/ui/theme.tres" id="2"]
[ext_resource type="FontFile" path="res://assets/fonts/Orbitron.ttf" id="3"]
[ext_resource type="Shader" path="res://assets/shaders/blur_dim.gdshader" id="4"]
[ext_resource type="Shader" path="res://assets/shaders/gradient_vision.gdshader" id="5"]

[sub_resource type="ShaderMaterial" id="ShaderMaterial_blur"]
shader = ExtResource("4")

[sub_resource type="ShaderMaterial" id="ShaderMaterial_vision"]
shader = ExtResource("5")
shader_parameter/vignette_amount = 0.7
shader_parameter/opacity = 0.75

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_btn"]
content_margin_left = 26.0
content_margin_top = 11.0
content_margin_right = 26.0
content_margin_bottom = 11.0
bg_color = Color(0.043, 0.075, 0.145, 0.92)
border_width_left = 1
border_width_top = 1
border_width_right = 1
border_width_bottom = 1
border_color = Color(0.22, 0.78, 0.84, 0.5)
corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_right = 8
corner_radius_bottom_left = 8

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_btn_hover"]
content_margin_left = 26.0
content_margin_top = 11.0
content_margin_right = 26.0
content_margin_bottom = 11.0
bg_color = Color(0.961, 0.651, 0.137, 1)
corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_right = 8
corner_radius_bottom_left = 8

[node name="ResultScreen" type="CanvasLayer"]
layer = 5
script = ExtResource("1")

[node name="Panel" type="Control" parent="."]
unique_name_in_owner = true
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("2")

[node name="Dim" type="ColorRect" parent="Panel"]
layout_mode = 1
material = SubResource("ShaderMaterial_blur")
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.6)

[node name="GradientVision" type="ColorRect" parent="Panel"]
layout_mode = 1
material = SubResource("ShaderMaterial_vision")
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

[node name="Center" type="CenterContainer" parent="Panel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Panel/Center"]
layout_mode = 2
theme_override_constants/separation = 14

[node name="Title" type="Label" parent="Panel/Center/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.42, 0.749, 0.349, 1)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 42
text = "MACHINE AWAKENED"
horizontal_alignment = 1

[node name="Rank" type="Label" parent="Panel/Center/VBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(0.961, 0.651, 0.137, 1)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 72
text = "S"
horizontal_alignment = 1

[node name="FlawlessBadge" type="Label" parent="Panel/Center/VBox"]
unique_name_in_owner = true
visible = false
layout_mode = 2
theme_override_colors/font_color = Color(0.42, 0.749, 0.349, 1)
theme_override_fonts/font = ExtResource("3")
theme_override_font_sizes/font_size = 20
text = "★ FLAWLESS — NO REWINDS USED"
horizontal_alignment = 1

[node name="Stats" type="Label" parent="Panel/Center/VBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(0.82, 0.84, 0.87, 1)
theme_override_font_sizes/font_size = 19
text = "TIME  00:00
TARGETS  0 / 0
KICKS USED  0
REWINDS USED  0"
horizontal_alignment = 1

[node name="Buttons" type="HBoxContainer" parent="Panel/Center/VBox"]
layout_mode = 2
theme_override_constants/separation = 14
alignment = 1

[node name="RetryButton" type="Button" parent="Panel/Center/VBox/Buttons"]
layout_mode = 2
theme_override_font_sizes/font_size = 16
theme_override_styles/normal = SubResource("StyleBoxFlat_btn")
theme_override_styles/hover = SubResource("StyleBoxFlat_btn_hover")
theme_override_colors/font_color = Color(0.918, 0.918, 0.918, 1)
theme_override_colors/font_hover_color = Color(0.04, 0.05, 0.09, 1)
text = "RETRY"

[node name="NextButton" type="Button" parent="Panel/Center/VBox/Buttons"]
layout_mode = 2
theme_override_font_sizes/font_size = 16
theme_override_styles/normal = SubResource("StyleBoxFlat_btn")
theme_override_styles/hover = SubResource("StyleBoxFlat_btn_hover")
theme_override_colors/font_color = Color(0.918, 0.918, 0.918, 1)
theme_override_colors/font_hover_color = Color(0.04, 0.05, 0.09, 1)
text = "NEXT LEVEL"

[node name="MenuButton" type="Button" parent="Panel/Center/VBox/Buttons"]
layout_mode = 2
theme_override_font_sizes/font_size = 16
theme_override_styles/normal = SubResource("StyleBoxFlat_btn")
theme_override_styles/hover = SubResource("StyleBoxFlat_btn_hover")
theme_override_colors/font_color = Color(0.918, 0.918, 0.918, 1)
theme_override_colors/font_hover_color = Color(0.04, 0.05, 0.09, 1)
text = "MAIN MENU"

[connection signal="pressed" from="Panel/Center/VBox/Buttons/RetryButton" to="." method="_on_retry_pressed"]
[connection signal="pressed" from="Panel/Center/VBox/Buttons/NextButton" to="." method="_on_next_pressed"]
[connection signal="pressed" from="Panel/Center/VBox/Buttons/MenuButton" to="." method="_on_menu_pressed"]
