[node name="Title" type="Label" parent="Panel/Center/Card/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.15, 0.95, 1, 1)
theme_override_colors/font_outline_color = Color(0, 0, 0, 1)
theme_override_constants/outline_size = 4
theme_override_fonts/font = ExtResource("5")
theme_override_font_sizes/font_size = 32
text = "THE STORY"
horizontal_alignment = 1

[node name="Body" type="Label" parent="Panel/Center/Card/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.86, 0.88, 0.92, 1)
theme_override_fonts/font = ExtResource("6")
theme_override_font_sizes/font_size = 17
theme_override_constants/line_spacing = 3
text = "There was a time when the lights never went out — when these halls sang all night. That was a long time ago.

One worker stayed behind, keeping the dead machines company. He believed the factory was only waiting — so he built one final invention: a ball made to wake a machine with a single kick. He never saw it finished.

Years later, a kid found the workshop — the ball still glowing on the bench, beside a note that said only, \"Wake them.\"

One kick is all it takes — gear by gear, room by room — until the whole factory breathes again."
autowrap_mode = 3

