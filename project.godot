; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Final Kick"
run/main_scene="res://scenes/ui/opening_cinematic.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="res://assets/audio/bus_layout.tres"

[autoload]

AudioDirector="*res://scripts/audio_director.gd"
LevelFlow="*res://scripts/level_flow.gd"
NarratorManager="*res://scripts/narrator_manager.gd"
LifeManager="*res://scripts/life_manager.gd"
FactoryManager="*res://scripts/factory_manager.gd"
ScoreManager="*res://scripts/score_manager.gd"
InstructionsPanel="*res://scenes/ui/instructions_panel.tscn"
Difficulty="*res://scripts/difficulty.gd"
SettingsPanel="*res://scenes/ui/settings_panel.tscn"
DifficultyPanel="*res://scenes/ui/difficulty_panel.tscn"
Leaderboard="*res://scripts/leaderboard.gd"
LeaderboardPanel="*res://scenes/ui/leaderboard_panel.tscn"
MainMenuPanel="*res://scenes/ui/main_menu_panel.tscn"
SceneTransition="*res://scenes/ui/scene_transition.tscn"
StoryPanel="*res://scenes/ui/story_panel.tscn"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

kick={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":32,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
